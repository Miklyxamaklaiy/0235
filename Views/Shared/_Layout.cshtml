@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Anti
@{
    var tokens = Anti.GetAndStoreTokens(Context);
    var title = ViewData["Title"] as string ?? "Плечо помощи";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content="@tokens.RequestToken" />
    <title>@title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Head", required: false)
</head>
<body data-auth="@(User.Identity?.IsAuthenticated == true ? "1" : "0")" data-role="@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "")">
<header class="pp-header">
    <div class="pp-shell pp-header-row">
        <button class="pp-burger" type="button" data-bs-toggle="offcanvas" data-bs-target="#ppMenu" aria-controls="ppMenu" aria-label="Меню">
            <span></span><span></span><span></span>
        </button>

        <nav class="pp-topnav d-none d-md-flex">
            <a class="pp-navlink" asp-controller="Home" asp-action="Index" asp-fragment="list">Учреждения</a>
            <a class="pp-navlink" asp-controller="Volunteer" asp-action="Index">Для волонтёров</a>
            <a class="pp-navlink" asp-controller="Contacts" asp-action="Index">Контакты</a>
        </nav>

        <div class="pp-header-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="dropdown">
                    <button class="pp-outline-btn dropdown-toggle" data-bs-toggle="dropdown">@User.Identity!.Name</button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><span class="dropdown-item-text small text-muted">Роль: @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item" asp-controller="Requests" asp-action="My">Мои заявки</a></li>
                        @if (User.IsInRole("Volunteer") || User.IsInRole("Admin"))
                        {
                            <li><a class="dropdown-item" asp-controller="Requests" asp-action="All">Лента заявок</a></li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Админ‑панель</a></li>
                        }
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="px-3 pb-2">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-dark w-100" type="submit">Выйти</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a class="pp-outline-btn" asp-controller="Account" asp-action="Login">Вход</a>
            }
        </div>
    </div>
</header>

<div class="offcanvas offcanvas-start pp-offcanvas" tabindex="-1" id="ppMenu" aria-labelledby="ppMenuLabel">
    <div class="offcanvas-header border-0">
        <div class="offcanvas-title" id="ppMenuLabel">Меню</div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
    </div>
    <div class="offcanvas-body">
        <div class="pp-menu-list">
            <a class="pp-menuitem" asp-controller="Home" asp-action="Index">Главная</a>
            <a class="pp-menuitem" asp-controller="About" asp-action="Index">О нас</a>
            <a class="pp-menuitem" asp-controller="Stories" asp-action="Index">Истории</a>
        </div>
    </div>
</div>

<main class="pp-main">
    @RenderBody()
</main>

<footer class="pp-footer" id="contacts">
    <div class="pp-shell pp-footer-row">
        <div class="pp-footer-contacts">
            <div>Контакты</div>
            <div>Email: Zaycevaa2007@gmail.com</div>
            <div>Телефон: +7 (917) 171-51-48</div>
        </div>
        <div class="pp-footer-copy">© 2025 «Плечо помощи». Все права защищены.</div>
        <div class="pp-footer-social">VK</div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
