@model ForgotPasswordVm
@{
    ViewData["Title"] = "Забыли пароль";
}
<div class="pp-shell pp-page-block">
    <div class="pp-form-stage pp-form-stage-center">
        <div class="pp-form-card pp-form-card-wide text-center">
            <h1 class="pp-form-title pp-form-title-center">Забыли пароль?</h1>
            <div class="pp-center-sub">Введите адрес электронной почты, связанный с вашим аккаунтом</div>

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger mt-3">@TempData["error"]</div>
            }

            <form method="post" class="pp-clean-form mt-4 text-start">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label>Почта</label>
                    <input class="form-control pp-input" asp-for="Email" />
                    <span class="text-danger small" asp-validation-for="Email"></span>
                </div>
                <button class="pp-outline-btn pp-big-btn w-100" type="submit">Отправить ссылку</button>
            </form>

            @if (ViewBag.Done == true)
            {
                <div class="alert alert-info mt-3 text-start">
                    @if (!string.IsNullOrWhiteSpace(Model.GeneratedLink))
                    {
                        <span>Ссылка для восстановления подготовлена: <a href="@Model.GeneratedLink">открыть форму</a></span>
                    }
                    else
                    {
                        <span>Если аккаунт существует, данные для восстановления обновлены.</span>
                    }
                </div>
            }
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
