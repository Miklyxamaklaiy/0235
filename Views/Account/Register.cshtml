@model RegisterVm
@{
    ViewData["Title"] = "Регистрация";
}
<div class="pp-shell pp-page-block">
    <div class="pp-form-stage pp-form-stage-center">
        <div class="pp-form-card pp-form-card-wide">
            <h1 class="pp-form-title">Регистрация</h1>
            <form method="post" class="pp-clean-form">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label>Фамилия</label>
                        <input class="form-control pp-input" asp-for="LastName" />
                        <span class="text-danger small" asp-validation-for="LastName"></span>
                    </div>
                    <div class="col-md-6">
                        <label>Имя</label>
                        <input class="form-control pp-input" asp-for="FirstName" />
                        <span class="text-danger small" asp-validation-for="FirstName"></span>
                    </div>
                </div>
                <div class="mb-3 mt-3">
                    <label>Почта</label>
                    <input class="form-control pp-input" asp-for="Email" />
                    <span class="text-danger small" asp-validation-for="Email"></span>
                </div>
                <div class="mb-1">
                    <label>Пароль</label>
                    <input class="form-control pp-input" asp-for="Password" type="password" />
                    <span class="text-danger small" asp-validation-for="Password"></span>
                    <div class="pp-hint">Пароль должен состоять минимум из 8 символов</div>
                </div>
                <div class="mb-1 mt-3">
                    <label>Повторите пароль</label>
                    <input class="form-control pp-input" asp-for="ConfirmPassword" type="password" />
                    <span class="text-danger small" asp-validation-for="ConfirmPassword"></span>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3 mb-4 small gap-3 flex-wrap">
                    <label class="d-flex align-items-center gap-2"><input type="checkbox" disabled /> Запомнить меня</label>
                    <a class="pp-text-link" asp-controller="Account" asp-action="ForgotPassword">Забыли пароль?</a>
                </div>
                <button class="pp-outline-btn pp-big-btn w-100" type="submit">Зарегистрироваться</button>
            </form>
            <div class="pp-form-bottom-link">Уже есть аккаунт? <a class="pp-text-link" href="/Account/Login">Войти</a></div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
